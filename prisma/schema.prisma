// Overboard Organizer schema
// User accounts are fully isolated — every query must filter by userId.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Lane {
  BACKLOG
  TODO
  DOING
  DONE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions Session[]
  projects Project[]
  ideas    Idea[]
  tokens   Token[]
  tags     Tag[]
}

model Token {
  id         String    @id @default(cuid())
  userId     String
  hash       String    @unique
  label      String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  priority  Int      @default(1) // lower = higher in list; can be 0 or negative
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([userId])
  @@index([userId, priority])
}

model Card {
  id          String   @id @default(cuid())
  projectId   String
  lane        Lane
  order       Int
  title       String
  contentJson String? // ProseMirror JSON from TipTap
  contentMd   String? // Markdown export
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tags    CardTag[]

  @@index([projectId])
  @@index([projectId, lane, order])
}

model Idea {
  id          String   @id @default(cuid())
  userId      String
  order       Int
  title       String
  contentJson String?
  contentMd   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags IdeaTag[]

  @@index([userId])
  @@index([userId, order])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String // normalized lowercase
  color     String? // optional hex override; otherwise derived from name
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards CardTag[]
  ideas IdeaTag[]

  @@unique([userId, name])
  @@index([userId])
}

model CardTag {
  cardId String
  tagId  String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@index([tagId])
}

model IdeaTag {
  ideaId String
  tagId  String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
  @@index([tagId])
}
