// Overboard Organizer schema
// User accounts are fully isolated — every query must filter by userId.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Lane {
  BACKLOG
  TODO
  DOING
  DONE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions Session[]
  projects Project[]
  ideas    Idea[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Int
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([userId])
  @@index([userId, order])
}

model Card {
  id          String   @id @default(cuid())
  projectId   String
  lane        Lane
  order       Int
  title       String
  contentJson String? // ProseMirror JSON from TipTap
  contentMd   String? // Markdown export
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, lane, order])
}

model Idea {
  id          String   @id @default(cuid())
  userId      String
  order       Int
  title       String
  contentJson String?
  contentMd   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, order])
}
